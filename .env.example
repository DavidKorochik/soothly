# Neon serverless Postgres — used by Drizzle (db:push) and the app at runtime.
DATABASE_URL=

# Anthropic — interview streaming + synthesis (Step 2+).
ANTHROPIC_API_KEY=

# OpenAI — Hebrew speech-to-text for optional voice dictation in the interview (gpt-4o-transcribe).
# The audio endpoint is no-train + zero abuse-retention by default; we never persist the raw audio.
# Without this key the mic still appears but transcription returns a "type instead" message.
OPENAI_API_KEY=

# Vercel Blob — stores generated PDFs (Step 2+).
BLOB_READ_WRITE_TOKEN=

# Resend — delivers the review link by email (Step 4).
RESEND_API_KEY=

# Public base URL, e.g. https://soothly.vercel.app (used in emailed links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — shared secret the sweep-synthesis cron is authenticated with. Vercel sends it as
# "Authorization: Bearer <CRON_SECRET>"; if unset, the cron route refuses every request (fail-closed).
CRON_SECRET=
